<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/movieItemConstraintLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tvTitleNews"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/standard_margin_medium_16dp"
        android:layout_marginTop="@dimen/standard_margin_small_8dp"
        android:layout_marginEnd="@dimen/standard_margin_medium_16dp"
        android:fontFamily="@font/nunito_bold"
        android:textColor="@color/gray_900"
        android:textSize="@dimen/news_title_size"
        app:layout_constraintEnd_toStartOf="@+id/posterNewsImg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvNewsByLine"
        tools:ignore="MissingConstraints"
        tools:text="Title for item" />


    <TextView
        android:id="@+id/tvSubtitleNews"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/standard_margin_medium_16dp"
        android:layout_marginTop="@dimen/standard_margin_small_8dp"
        android:layout_marginEnd="@dimen/standard_margin_medium_16dp"
        android:layout_marginBottom="@dimen/standard_margin_medium_16dp"
        android:fontFamily="@font/nunito_regular"
        android:textColor="@color/gray_dark"
        android:textSize="@dimen/news_subtitle_size"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/posterNewsImg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvTitleNews"
        tools:text="Section plus author By Isai Garcia Moso" />

    <TextView
        android:id="@+id/tvNewsByLine"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/standard_margin_medium_16dp"
        android:layout_marginTop="@dimen/standard_margin_medium_16dp"
        android:layout_marginEnd="@dimen/standard_margin_medium_16dp"
        android:fontFamily="@font/nunito_light"
        android:textColor="@color/gray_text"
        android:textSize="@dimen/news_copyright_size"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="copyright Isaí Garcia Moso" />

    <ImageView
        android:id="@+id/posterNewsImg"
        android:layout_width="@dimen/news_width_image"
        android:layout_height="@dimen/news_height_image"
        android:layout_marginTop="@dimen/standard_margin_small_8dp"
        android:layout_marginEnd="@dimen/standard_margin_medium_16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvNewsByLine" />

    <View
        android:layout_width="wrap_content"
        android:layout_height="@dimen/news_divider_size"
        android:background="#F8F5F5"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>